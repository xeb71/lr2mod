<?xml version='1.0' encoding='UTF-8'?>
<!--
    HOW OUTFITS ARE ADDED TO THIS WARDROBE
    =======================================
    Each <Outfit> defines a complete swimwear combination that NPCs can wear
    at the pool.  The game randomly picks one outfit per NPC per day.

    FullSets      – complete outfit including all clothing layers.  Pool outfits
                    are FullSets (not OverwearSets) because swimwear IS the
                    entire outfit — there is no separate underwear layer.

    To add a new outfit:
      1. Copy an existing <Outfit> block inside <FullSets>.
      2. Change the "name" attribute to something unique and descriptive.
      3. Adjust colour values on each <Item>:
           red, green, blue  – main colour  (0.0–1.0)
           alpha             – opacity       (0.0–1.0, usually 0.95)
      4. Change the "name" attribute on <Item> to a valid clothing identifier
         from clothing_lists_ren.py (e.g. Sports_Bra, Strappy_Bra, Panties, etc.).
      5. The wardrobe XML is reloaded on every save-load via the compatibility
         fix, so new outfits take effect immediately on existing saves.
-->
<Wardrobe name="Pool Wardrobe">
    <FullSets>
        <!-- === White === -->
        <Outfit name="White Sports Bra Panties Pool">
            <UpperBody>
                <Item alpha="0.95" blue="0.95" green="0.95" name="Sports_Bra" red="0.95" />
            </UpperBody>
            <LowerBody>
                <Item alpha="0.95" blue="0.95" green="0.95" name="Panties" red="0.95" />
            </LowerBody>
            <Feet />
            <Accessories />
        </Outfit>
